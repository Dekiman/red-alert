{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://red-alert-backend.red-alert.workers.dev/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://red-alert-backend.red-alert.workers.dev/health"
    },
    {
      "source": "/ui-socket",
      "destination": "https://red-alert-backend.red-alert.workers.dev/ui-socket"
    }
  ]
}
