{
  "name": "red-alert",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:backend": "bun --filter backend dev",
    "dev:frontend": "bun --filter frontend dev",
    "build": "bun --filter '*' build",
    "deploy": "bun --filter backend deploy && bun --filter frontend deploy",
    "build:boundaries": "bun scripts/build-boundaries.ts",
    "build:mask": "bun scripts/build-earth-mask.ts",
    "lint": "oxlint .",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-server": "^3.0.4",
    "@types/topojson-simplify": "^3.0.3",
    "@typescript/native-preview": "^7.0.0-dev.20260516.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxlint": "^1.65.0",
    "topojson-client": "^3.1.0",
    "topojson-server": "^3.0.1",
    "topojson-simplify": "^3.0.3"
  }
}